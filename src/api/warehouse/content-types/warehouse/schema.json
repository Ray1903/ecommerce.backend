{
  "kind": "collectionType",
  "collectionName": "warehouses",
  "info": {
    "singularName": "warehouse",
    "pluralName": "warehouses",
    "displayName": "Warehouse",
    "description": "Centros de almacenamiento para frutas y verduras"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "address": {
      "type": "text",
      "required": true
    },
    "city": {
      "type": "string",
      "required": true
    },
    "state": {
      "type": "string",
      "required": true
    },
    "postalCode": {
      "type": "string"
    },
    "contactPhone": {
      "type": "string"
    },
    "contactEmail": {
      "type": "email"
    },
    "managerName": {
      "type": "string"
    },
    "produceFocus": {
      "type": "enumeration",
      "enum": [
        "fruits",
        "vegetables",
        "mixed"
      ],
      "default": "mixed"
    },
    "storageMode": {
      "type": "enumeration",
      "enum": [
        "ambient",
        "refrigerated",
        "mixed"
      ],
      "default": "ambient"
    },
    "operatingHours": {
      "type": "text"
    },
    "capacityKg": {
      "type": "decimal"
    },
    "minimumTemperature": {
      "type": "decimal"
    },
    "maximumTemperature": {
      "type": "decimal"
    },
    "acceptedCategories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "warehouses"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "sellers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::seller.seller",
      "mappedBy": "assignedWarehouse"
    }
  }
}
