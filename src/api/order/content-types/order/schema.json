{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "statusOrder": {
      "type": "enumeration",
      "enum": [
        "pending",
        "confirmed",
        "preparing",
        "out_for_delivery",
        "delivered",
        "cancelled"
      ]
    },
    "payment_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "paid",
        "failed",
        "refunded"
      ]
    },
    "subtotal": {
      "type": "decimal"
    },
    "deliveryFee": {
      "type": "decimal"
    },
    "total": {
      "type": "decimal"
    },
    "notes": {
      "type": "string"
    },
    "adress": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::adress.adress",
      "inversedBy": "orders"
    },
    "orderNumber": {
      "type": "string"
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "orders"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "order"
    },
    "deliveryAssigment": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::delivery-assigment.delivery-assigment",
      "mappedBy": "order"
    }
  }
}
