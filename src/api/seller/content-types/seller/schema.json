{
  "kind": "collectionType",
  "collectionName": "sellers",
  "info": {
    "singularName": "seller",
    "pluralName": "sellers",
    "displayName": "Seller"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "storeName": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "storeName"
    },
    "description": {
      "type": "string"
    },
    "contactPhone": {
      "type": "string"
    },
    "address": {
      "type": "json"
    },
    "profileImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "isVerified": {
      "type": "boolean",
      "default": false
    },
    "approvalStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "pending",
      "required": true
    },
    "warehouseAssignmentStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "assigned"
      ],
      "default": "pending",
      "required": true
    },
    "deliveryInstructions": {
      "type": "text"
    },
    "assignedWarehouse": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::warehouse.warehouse",
      "inversedBy": "sellers"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "seller"
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "seller"
    },
    "order_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "seller"
    },
    "deliveryRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::delivery-request.delivery-request",
      "mappedBy": "seller"
    }
  }
}
